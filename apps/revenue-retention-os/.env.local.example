# ─── Supabase (공개값) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Supabase (서버 전용) ────────────────────────────────────
# 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# ─── 초대 토큰 ──────────────────────────────────────────────
# core-api INVITE_TOKEN_SECRET과 동일한 값이어야 함
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INVITE_TOKEN_SECRET=

# ─── Super Admin ────────────────────────────────────────────
SUPER_ADMIN_EMAILS=

# ─── URL ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# core-api 서버 주소 (로컬: uvicorn 기본 포트 8001)
NEXT_PUBLIC_CORE_API_URL=http://localhost:8001
