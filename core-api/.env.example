# ─── Supabase ───────────────────────────────────────────────
# Supabase project URL (= NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_URL=

# Supabase service role key — 서버 전용, 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=

# Supabase dashboard > Settings > API > JWT Settings > JWT Secret
# HS256 서명 검증에 사용. Service Role Key와 다름.
SUPABASE_JWT_SECRET=

# ─── 토큰 ───────────────────────────────────────────────────
# 초대 토큰 HMAC 서명 키 — Next.js INVITE_TOKEN_SECRET과 동일한 값이어야 함
INVITE_TOKEN_SECRET=

# ─── 서버 설정 ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# CORS: 쉼표 구분 허용 origin
ALLOWED_ORIGINS=http://localhost:3000

# 초대 메일 redirect 등에 사용할 앱 base URL
APP_URL=http://localhost:3000

# ─── Super Admin ────────────────────────────────────────────
# 쉼표 구분 슈퍼어드민 이메일
SUPER_ADMIN_EMAILS=

# (선택) 슈퍼어드민 IP 화이트리스트 — 비우면 제한 없음
SUPER_ADMIN_IP_WHITELIST=
